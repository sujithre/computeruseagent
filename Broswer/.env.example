# Azure AI Foundry Project Endpoint
# Find this in the overview for your project in the Microsoft Foundry portal
# under Libraries > Foundry
PROJECT_ENDPOINT=https://your-project.api.azureml.ms

# Playwright Connection ID (full Azure resource ID format)
# Find this in the Foundry portal by selecting Management center > Connected resources
# Format: /subscriptions/<subscription_id>/resourceGroups/<resource_group>/providers/Microsoft.MachineLearningServices/workspaces/<workspace>/connections/<connection_name>
AZURE_PLAYWRIGHT_CONNECTION_NAME=/subscriptions/your-subscription-id/resourceGroups/your-resource-group/providers/Microsoft.MachineLearningServices/workspaces/your-workspace/connections/your-playwright-connection

# Model Deployment Name (for Browser Automation)
# Find this in Models + Endpoints in the left navigation menu of the Foundry portal
MODEL_DEPLOYMENT_NAME=gpt-4o

# Computer Use Model Deployment Name
# The deployment name for a model that supports Computer Use (e.g., computer-use-preview)
# If not set, will default to MODEL_DEPLOYMENT_NAME
COMPUTER_USE_MODEL_DEPLOYMENT_NAME=computer-use-preview

# Computer Use Environment
# The type of environment for Computer Use: windows, mac, linux, or browser
COMPUTER_USE_ENVIRONMENT=windows

# Azure Blob Storage for Screenshots (Container App only)
# Uses Managed Identity - no connection string needed
# Just provide the storage account name
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_CONTAINER_NAME=screenshots
